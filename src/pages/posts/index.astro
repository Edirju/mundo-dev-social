---
// src/pages/posts/index.astro
// Listado de todos los posts del CMS Content Island
// Se regenera en cada request (SSR dinámico)
export const prerender = false;

import Layout from "#layouts/Layout.astro";
import { getAllPost } from "#pods/post-collection/post-collection.api.ts";
import PostCollectionPod from "#pods/post-collection/post-collection.pod.astro";

const posts = await getAllPost();
---

<Layout title="Blog">
  <PostCollectionPod posts={posts} />
</Layout>
