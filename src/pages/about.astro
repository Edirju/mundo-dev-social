---
import Layout from "#layouts/Layout.astro";
import Grid from "#components/Grid.astro";
import Hero from "#components/Hero.astro";
import ToolCollection from "#pods/tools-collection/tool-collection.astro";
import Contacts from "#pods/about/Contacts.astro";
import CVBtn from "#pods/about/CV-Btn.astro";

import { basics } from "#data/cv.json";
const { name, label, image } = basics;
---

<Layout title={`Acerca de ${name} • ${label}`}>
  <Grid>
    <Hero ariaLabelledby="about-hero-heading" slot="hero">
      <section class="flex flex-col justify-center gap-6 md:flex-row md:gap-8">
        <picture class="size-25 md:size-40 overflow-hidden">
          <img
            src={image}
            alt={name}
            class="w-full h-full rounded-full object-cover grayscale"
          />
        </picture>

        <div class="flex flex-col flex-1 justify-center gap-4 max-w-[55ch]">
          <div>
            <h1
              id="about-hero-heading"
              class="text-2xl font-bold tracking-tight leading-tight"
            >
              {name}
            </h1>
            <p
              class="text-lg font-medium capitalize tracking-tighter text-[rgb(var(--color),0.65)]"
            >
              desarrollo web & social media
            </p>
          </div>
          <p
            class="text-base font-light tracking-tighter text-pretty leading-tight text-[rgb(var(--color),0.65)]"
          >
            Passionate about creating amazing web experiences with modern
            technologies. I love sharing knowledge through articles and
            workshops.
          </p>
        </div>
      </section>
    </Hero>

		<ToolCollection />

		<Fragment slot="aside">
			<Contacts />
			<CVBtn />
		</Fragment>
  </Grid>
</Layout>
