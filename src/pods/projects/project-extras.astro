---
import Section from "#components/Section.astro";
import Github from "#assets/icons/Github.astro";
import Data from "#assets/icons/Data.astro";
import Globe from "#assets/icons/Globe.astro";

import { projects } from "#data/cv.json";
---

<Section>
  <section
    class="flex flex-col flex-1 gap-6 md:gap-8 text-[rgb(var(--color),0.85)]"
  >
    <h3
      class="flex items-center gap-1 text-sm tracking-tight font-normal [&>svg]:size-5 [&>span]:font-extralight [&>span]:opacity-45 [&>strong]:text-secondary-500 dark:[&>strong]:text-tertiary-600 [&>strong]:underline [&>strong]:underline-offset-2"
    >
      <Data />
      <span>|</span> Proyectos <strong>extras</strong>:
    </h3>

    <ul class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-6 mx-0">
      {
        projects.map(
          ({ url, description, highlights, name, isActive, github }) => {
            return (
              <li>
                <article class="group p-4 border-0 sm:border sm:border-[rgb(var(--color),0.05)] rounded-xl sm:p-2 flex flex-col justify-between gap-2 h-full shadow-[8px_8px_24px_rgb(var(--color),0.08),-8px_-8px_24px_rgb(var(--color),0.02)] dark:shadow-[8px_8px_24px_rgb(0,0,0,0.25),-8px_-8px_24px_rgb(0,0,0,0.1)] hover:shadow-[0_0_18px_6px_rgb(var(--color),0.15)] dark:hover:shadow-[0_0_18px_6px_rgb(36,168,207,0.15)] backdrop-blur-2xl overflow-hidden transition-all duration-300">
                  <header>
                    <h4 class="flex items-center justify-between gap-1 mb-2 ">
                      <a
                        href={url}
                        title={`Ver demo: ${name}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-medium tracking-tighter transition-all group-hover:text-secondary-500 group-hover:underline group-hover:underline-offset-2 group-hover:text-shadow-[0_0_8px_rgb(var(--color),0.25)]"
                      >
                        {name}
                      </a>
                      {isActive && (
                        <span class="text-green-500 font-black text-base">
                          •
                        </span>
                      )}
                      {github && (
                        <a
                          href={github}
                          title={`Ver repositorio: ${name}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="[&>svg]:size-4 hover:text-tertiary-700 "
                        >
                          <Github />
                        </a>
                      )}
                    </h4>
                    <p class="font-inconsolata font-light text-xs tracking-tighter leading-tight text-pretty text-[rgb(var(--color),0.65)] ">
                      {description}
                    </p>
                  </header>
                  <footer class="">
                    <ul class="flex flex-wrap gap-1">
                      {highlights.map((highlight) => {
                        return (
                          <li class="text-[10px] font-light text-[rgb(var(--color),0.45)] bg-secondary-500/10 rounded-full py-0.5 px-1 w-fit">
                            {highlight}
                          </li>
                        );
                      })}
                    </ul>
                  </footer>
                </article>
              </li>
            );
          },
        )
      }
    </ul>
  </section>
</Section>
