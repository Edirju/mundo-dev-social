---
import Html5 from "#assets/icons/Html5.astro";
import Css3 from "#assets/icons/Css3.astro";
import Javascript from "#assets/icons/Javascript.astro";
import AstroJS from "#assets/icons/AstroJS.astro";
import React from "#assets/icons/React.astro";
import TailwindCss from "#assets/icons/TailwindCss.astro";
import Gemini from "#assets/icons/Gemini.astro";
import Figma from "#assets/icons/Figma.astro";
import ChatGpt from "#assets/icons/ChatGpt.astro";
import Notion from "#assets/icons/Notion.astro";
import Trello from "#assets/icons/Trello.astro";
import Tools from "#assets/icons/Tools.astro";
import Brain from "#assets/icons/Brain.astro";

const SKILLS_ICON: Record<string, any> = {
  Html5,
  Css3,
  Javascript,
  AstroJS,
  React,
  TailwindCss,
  Gemini,
  Figma,
  ChatGpt,
  Notion,
  Trello,
  Tools,
  Brain,
};

const skills1 = [
  { name: "Figma", icon: "Figma" },
  { name: "Gemini", icon: "Gemini" },
  { name: "ChatGpt", icon: "ChatGpt" },
];

const skills2 = [
  { name: "React", icon: "React" },
  { name: "Tailwind", icon: "TailwindCss" },
  { name: "Astro", icon: "AstroJS" },
  { name: "HTML5", icon: "Html5" },
];

const skills3 = [
  { name: "JS", icon: "Javascript" },
  { name: "Notion", icon: "Notion" },
  { name: "Trello", icon: "Trello" },
  { name: "Tools", icon: "Tools" },
  { name: "Brain", icon: "Brain" },
];

const orbits = [
  { skills: skills1, radius: 120, duration: 14, reverse: false },
  { skills: skills2, radius: 200, duration: 22, reverse: true },
  { skills: skills3, radius: 290, duration: 32, reverse: false },
];
---

<section class="font-inter-tight text-[rgb(var(--color),0.85)]">
  <div
    class="container px-4 md:px-0 py-8 md:py-0 mx-auto flex flex-wrap "
  >
    <div
      class="flex flex-wrap -mx-4 mt-auto mb-auto lg:w-1/2 sm:w-2/3 content-start sm:pr-10"
    >
      <div class="w-full sm:p-4 px-4 mb-6">
        <h1 class="font-semibold text-xl mb-2 tracking-tighter text-[rgb(var(--color),0.85)]">
          Proyectos <span class="font-light opacity-65">&</span> Prácticas:
        </h1>
        <p class="leading-relaxed text-[rgb(var(--color),0.65)] [&>strong]:font-medium [&>strong]:text-[rgb(var(--color),0.75)] [&>strong]:text-shadow-[0_0_4px_rgb(var(--color),0.25)] ">
          El objetivo es <strong>mejorar</strong> habilidades de desarrollo web. Compartiendo
          <strong>conocimientos</strong> y trabajos <strong>para ayudar</strong> a
          otros a alcanzar sus metas.
        </p>
      </div>

      <div class="p-4 sm:w-1/2 lg:w-1/3 w-1/2">
        <h2 class="font-medium text-lg text-[rgb(var(--color),0.65)] tracking-tighter">+100</h2>
        <p
          class="text-xs font-inconsolata text-[rgb(var(--color),0.55)] font-light tracking-tight leading-relaxed"
        >
          Proyectos
        </p>
      </div>

      <div class="p-4 sm:w-1/2 lg:w-1/3 w-1/2">
        <h2 class="font-medium text-lg text-[rgb(var(--color),0.65)] tracking-tighter">+50hr</h2>
        <p
          class="text-xs font-inconsolata text-[rgb(var(--color),0.55)] font-light tracking-tight leading-relaxed"
        >
          Prácticas
        </p>
      </div>
      
      <div class="p-4 sm:w-1/2 lg:w-1/3 w-1/2">
        <h2 class="font-medium text-lg text-[rgb(var(--color),0.65)] tracking-tighter">+15</h2>
        <p
          class="text-xs font-inconsolata text-[rgb(var(--color),0.55)] font-light tracking-tight leading-relaxed"
        >
          Calidad
        </p>
      </div>
    </div>

    <figure
      class="orbit-col self-stretch relative lg:w-1/2 sm:w-1/3 w-full h-55 rounded-lg overflow-hidden mt-6 sm:mt-0 bg-[rgb(var(--light),0.05)] dark:bg-[rgb(var(--dark),0.05)] backdrop-blur-2xl backdrop-saturate-100"
    >
      <div
        class="orbit-scene absolute bottom-0 right-0 size-120 md:size-160 transform-[translate(50%,50%)] flex items-center justify-center pointer-events-none"
      >
        <div class="center-dot absolute size-1.5 rounded-full bg-[#d1d5db] z-2">
        </div>
        {
          orbits.map(({ skills, radius, duration, reverse }) => (
            <div
              class={`orbit-ring ${reverse ? "reverse" : ""} absolute w-(--orbit-size) h-(--orbit-size) rounded-full border border-dashed border-[#e5e7eb] `}
              style={`--radius:${radius}px; --duration:${duration}s; --orbit-size:${radius * 2}px;`}
            >
              <ul class="orbit-list list-none m-0 p-0 relative size-full ">
                {skills.map(({ name, icon }, index) => {
                  const Icon = SKILLS_ICON[icon];
                  return Icon ? (
                    <li
                      class="orbit-item absolute top-[50%] left-[50%] w-0 h-0 "
                      style={`--index:${index}; --total:${skills.length}; --angle:${(index / skills.length) * 360}deg;`}
                    >
                      <div
                        class={`icon-wrapper ${reverse ? "upright-reverse" : "upright-normal"} size-8 rounded-full bg-[rgb(var(--light),0.65)] border border-[#e5e7eb] shadow-[0_1px_4px_rgb(0_0_0/0.08)] flex items-center justify-center transform-[translate(-50%,-50%)] pointer-events-auto [&>svg]:text-[rgb(var(--color),0.85)] `}
                        style={`--duration:${duration}s;`}
                      >
                        <Icon />
                        <span class="sr-only">{name}</span>
                      </div>
                    </li>
                  ) : null;
                })}
              </ul>
            </div>
          ))
        }
      </div>
      <!-- <Image
        src={Img1}
        alt="image"
        class="object-cover object-center size-full"
      /> -->
      <!-- <img
        class="object-cover object-center w-full h-full"
        src="https://dummyimage.com/600x300"
        alt="stats"
      /> -->
    </figure>
  </div>
</section>

<style>
  .orbit-col {
    mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(var(--color)) 30%,
      transparent 100%
    );
  }

  .orbit-ring {
    animation: spin var(--duration) linear infinite;
  }

  .orbit-ring.reverse {
    animation-direction: reverse;
  }

  .orbit-item {
    transform: rotate(calc((var(--index) / var(--total)) * 360deg))
      translateY(calc(var(--radius) * -1));
  }

  .icon-wrapper.upright-normal {
    animation: upright-ccw var(--duration) linear infinite;
  }

  .icon-wrapper.upright-reverse {
    animation: upright-cw var(--duration) linear infinite;
  }

  .icon-wrapper :global(svg) {
    width: 1rem;
    height: 1rem;
    color: #6b7280;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes upright-ccw {
    from {
      /* transform: translate(-50%, -50%) rotate(0deg); */
      transform: translate(-50%, -50%) rotate(calc(var(--angle) * -1));
    }
    to {
      /* transform: translate(-50%, -50%) rotate(-360deg); */
      transform: translate(-50%, -50%) rotate(calc(var(--angle) * -1 + 360deg));
    }
  }

  @keyframes upright-cw {
    from {
      /* transform: translate(-50%, -50%) rotate(0deg); */
      transform: translate(-50%, -50%) rotate(calc(var(--angle) * -1));
    }
    to {
      /* transform: translate(-50%, -50%) rotate(360deg); */
      transform: translate(-50%, -50%) rotate(calc(var(--angle) * -1 + 360deg));
    }
  }
</style>
