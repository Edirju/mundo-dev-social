---
interface Props {
  name: string;
  role: string;
  image: ImageMetadata;
  rotateTooltip?: "left" | "right" | "none";
  roleColor?: string;
}

import { Image } from "astro:assets";

const {
  name,
  role,
  image,
  rotateTooltip = "none",
  roleColor = "text-gray-400",
} = Astro.props;

const rotateClass =
  rotateTooltip === "left"
    ? "rotate-[-10deg] origin-bottom"
    : rotateTooltip === "right"
      ? "rotate-10 origin-bottom"
      : "";
---

<div class="relative group cursor-pointer">
  <div
    class:list={[
      `absolute -top-14 left-1/2 -translate-x-1/2`,
      "bg-[rgb(var(--color))] text-[rgb(var(--light))] dark:text-[rgb(var(--dark))]",
      "font-inconsolata tracking-wide py-1 px-2 rounded-md",
      "transition-opacity duration-300 pointer-events-none whitespace-nowrap z-10 shadow-xl",
      "opacity-0 group-hover:opacity-100",
      rotateClass,
    ]}
  >
    <div class="flex flex-col gap-0.5 items-center justify-center">
      <span class="font-medium text-xs">{name}</span>
      <span class:list={[`text-[10px] -mt-1`, roleColor]}>{role}</span>
    </div>
    <div
      class="absolute -bottom-1 left-1/2 -translate-x-1/2 size-2.5 bg-[rgb(var(--color))] rotate-45"
    >
    </div>
  </div>
  <Image
    src={image}
    alt={name}
    width={40}
    height={40}
    class="size-10 rounded-full border-2 border-amber-400 object-cover transition-all duration-300 relative group-hover:scale-105 group-hover:z-20 grayscale group-hover:grayscale-0 group-hover:shadow-[0_0_12px_rgb(var(--color),0.25)]"
  />
</div>
