---
import Section from "#components/Section.astro";
import Spreadsheet from "#assets/icons/Spreadsheet.astro";
import Heart from "#assets/icons/Heart.astro";

import FormattedDate from "#components/FormattedDate.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const posteos = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Section>
  <section class="flex flex-col flex-1 gap-8">
    <h3
      class="flex items-center gap-1 text-sm tracking-tight font-normal [&>svg]:size-5 [&>span]:font-extralight [&>span]:opacity-45"
    >
      <Spreadsheet /> Blog <span>|</span> Notas recientes:
    </h3>

    <div
      class="grid max-w-175 gap-6 grid-cols-1 justify-center sm:grid-cols-2 md:grid-cols-3"
    >
      {
        posteos.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            title={`Ver artículo: ${post.data.title}`}
            class="group rounded-xl border border-[rgb(var(--color),0.05)] p-2 bg-[rgb(var(--light),0.05)] dark:bg-[rgb(var(--dark),0.10)] backdrop-blur-2xl backdrop-saturate-100 overflow-hidden shadow-[0_0_12px_rgb(var(--color),0.1)] dark:shadow-[0_0_12px_rgb(0_0_0/0.25)]"
          >
            <article class="flex flex-col h-full">
              <figure class="aspect-video overflow-hidden rounded-xl @lg:flex-1">
                {post.data.heroImage && (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class={`size-full rounded-xl object-cover transition-all duration-300 group-hover:scale-[1.06] grayscale group-hover:grayscale-0`}
                  />
                )}
              </figure>

              <div class="flex flex-col gap-1.5 justify-between flex-1 mt-1.5 @lg:flex-2">
                <div class="flex flex-col gap-1">
                  <time class="block font-inconsolata font-light text-xs tracking-tighter">
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                  <h4 class="text-base font-medium tracking-tight leading-[1.15] transition-all duration-300 group-hover:text-secondary-500">
                    {post.data.title}.
                  </h4>
                  <p class="text-xs font-light leading-tight opacity-65">
                    {post.data.description}
                  </p>
                </div>

                <div class="font-inconsolata flex items-center justify-between gap-4 text-xs font-light tracking-wide transition-opacity hover:opacity-65">
                  <span>1 min read</span>
                  <div class="flex items-center gap-1 [&>svg]:size-4">
                    <Heart aria-hidden="true" />
                    <span>6</span>
                  </div>
                </div>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </section>
</Section>
