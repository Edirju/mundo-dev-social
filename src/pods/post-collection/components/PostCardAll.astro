---
import Heart from "#assets/icons/Heart.astro";
import Info from "#assets/icons/Info.astro";

import type { Post } from "../post.collection.model";
interface Props {
  post: Post;
}
const { post } = Astro.props;
const readTimeLabel = "min read";
---

<a
  href={`/posts/${post.slug}`}
  title={`Ver publicación: ${post.title}`}
  class="group rounded-xl border border-[rgb(var(--color),0.05)] p-2 bg-[rgb(var(--light),0.05)] dark:bg-[rgb(var(--dark),0.10)] backdrop-blur-2xl backdrop-saturate-100 overflow-hidden shadow-[0_0_12px_rgb(var(--color),0.1)] dark:shadow-[0_0_12px_rgb(0_0_0/0.25)]"
>
  <article class="flex flex-col h-full">
    <figure class="aspect-video overflow-hidden rounded-xl @lg:flex-1">
      <img
        src={post.image.url}
        alt={post.title}
        aria-hidden="true"
        class="size-full rounded-xl object-cover transition-all duration-300 group-hover:scale-[1.06] grayscale group-hover:grayscale-0"
      />
    </figure>

    <div class="flex flex-col gap-1.5 justify-between flex-1 mt-1.5 @lg:flex-2">
      <div class="flex flex-col gap-1">
        <time
          datetime={post.date}
          class="block font-inconsolata font-light text-xs tracking-tighter"
        >
          {
            new Date(post.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          }
        </time>
        <h4
          class="text-base font-medium tracking-tight leading-[1.15] transition-all duration-300 group-hover:text-secondary-500"
          transition:name={`${post.title}-title`}
        >
          {post.title}.
        </h4>
        <p class="text-xs font-light leading-tight opacity-65">
          {post.summary}
        </p>
      </div>

      <div
        class="font-inconsolata flex items-center justify-between gap-4 text-xs font-light tracking-wide transition-opacity hover:opacity-65"
      >
        <span>{post.readTime} {readTimeLabel}</span>
        <div class="flex items-center gap-1 [&>svg]:size-4">
          <Heart aria-hidden="true" />
          <span>{6}</span>
        </div>
      </div>
    </div>
  </article>
</a>
