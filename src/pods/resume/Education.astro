---
import Section from "#components/Section.astro";
import { education } from "#data/cv.json";
---

<Section title="Formación Académica">
  <ul
    class="flex flex-col gap-4 list-none text-sm text-[rgb(var(--dark),0.85)]"
  >
    {
      education.map(
        ({
          institution,
          url,
          area,
          studyType,
          startDate,
          endDate,
          courses,
          score,
        }) => {
          const startYear = new Date(startDate).getFullYear();
          const endYear =
            endDate != null ? new Date(endDate).getFullYear() : "Actual";
          const years = `${startYear} - ${endYear}`;

          return (
            <li>
              <article>
                <header class="flex items-start justify-between mb-2">
                  <div>
                    <h3 class="text-base font-semibold text-pretty tracking-tighter transition-all duration-300 hover:underline hover:underline-offset-2">
                      <a
                        href={url}
                        title={`Ver más de ${institution}`}
                        target="_blank"
                      >
                        {institution}
                      </a>
                    </h3>
                    <h4 class="text-sm font-medium tracking-tight">
                      {area}
                    </h4>
                  </div>
                  <time class="text-sm font-inconsolata opacity-65 min-w-25.5 tracking-tighter md:text-right">
                    {years}
                  </time>
                </header>

                <footer class="text-xs font-inconsolata text-[rgb(var(--dark),0.85)]">
                  <p class="flex gap-4 tracking-tighter m-0 p-0 leading-tight ">
                    {studyType}
                  </p>
                  <p class="flex gap-4 tracking-tighter m-0 p-0 leading-tight ">
                    {courses}
                  </p>
                </footer>
              </article>
            </li>
          );
        },
      )
    }
  </ul>
</Section>
