---
import ContactBtn from "#components/ContactBtn.astro";
import User from "#assets/icons/User.astro";

const contactContent = {
  heading: "Contacto",
  description:
    "Si quieres ponerte en contacto conmigo, puedes hacerlo a traves de las siguientes redes sociales.",
};
---

<aside
  aria-labelledby="contact-aside-heading"
  class="flex flex-col gap-2 p-4 bg-[rgb(var(--dark),0.05)] dark:bg-[rgb(var(--light),0.08)] rounded-xl backdrop-blur-2xl backdrop-saturate-100"
>
  <h3
    class="flex items-center gap-1 text-base font-semibold tracking-tighter text-pretty [&>span]:font-light [&>span]:opacity-45 animate-fade-in-right"
  >
    <User />
    <span>|</span>
    {contactContent.heading}
  </h3>
  <p
    class="text-sm font-light text-[rgb(var(--color),0.65)] tracking-tighter mb-1 animate-fade-in-up"
  >
    {contactContent.description}
  </p>
  <ContactBtn />
</aside>
