---
import Logo from "#assets/icons/LogoER.astro";
import HeaderLink from "./HeaderLink.astro";
---

<header
  class="sticky top-0 z-100 bg-[rgb(var(--light),0.15)] dark:bg-[rgb(var(--dark),0.25)] backdrop-blur-xl backdrop-saturate-100 mb-8 sm:mb-12 md:mb-16 animate-fade-in-down"
>
  <div
    class="max-w-2xl mx-auto p-4 flex items-center justify-between sm:px-0 md:max-w-175"
  >
    <div>
      <a
        href="/"
        class="flex items-center gap-0.5 text-[rgb(var(--color),0.85)] hover:text-secondary-500 transition-all duration-300 rtl:flex-row-reverse"
      >
        <span class="sr-only">Logo</span>
        <Logo />
        <h1
          class="flex items-center gap-0.5 text-xl font-semibold font-inter-tight tracking-tighter whitespace-nowrap self-center [&>span]:font-extralight [&>span]:opacity-45"
        >
          dirju <span>|</span> un blog mío...
        </h1>
      </a>
    </div>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        class="relative size-7 border border-primary-900/15 rounded-full flex items-center justify-center bg-[rgb(var(--dark))] text-[rgb(var(--light))] cursor-pointer transition-all duration-300 hover:shadow-[0_0_12px_rgb(var(--color),0.15)] hover:bg-[rgb(var(--dark),0.85)]"
      >
        <span class="sr-only">toggle theme</span>
        <div class="relative size-4 overflow-hidden">
          <svg
            class="absolute h-full w-full scale-100 rotate-0 opacity-100 transition-all duration-500 dark:scale-0 dark:-rotate-90 dark:opacity-0"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"
              fill="currentColor"></path>
          </svg>
          <svg
            class="absolute h-full w-full scale-0 rotate-90 opacity-0 transition-all duration-500 dark:scale-100 dark:rotate-0 dark:opacity-100"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 2V4M12 20V22M4 12H2M6.31412 6.31412L4.8999 4.8999M17.6859 6.31412L19.1001 4.8999M6.31412 17.69L4.8999 19.1042M17.6859 17.69L19.1001 19.1042M22 12H20M17 12C17 14.7614 14.7614 17 12 17C9.23858 17 7 14.7614 7 12C7 9.23858 9.23858 7 12 7C14.7614 7 17 9.23858 17 12Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
        </div>
      </button>

      <button
        id="menu-toggle"
        data-collapse-toggle="navbar-default"
        type="button"
        aria-controls="navbar-default"
        aria-expanded="false"
        class="group relative size-7 border border-primary-900/15 rounded-full flex items-center justify-center bg-[rgb(var(--dark))] text-[rgb(var(--light))] cursor-pointer transition-all duration-300 hover:shadow-[0_0_12px_rgb(var(--color),0.15)] hover:bg-[rgb(var(--dark),0.85)]"
      >
        <span class="sr-only">toggle menu</span>
        <div class="relative size-4 overflow-hidden">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="absolute size-full transition-all duration-500 transform scale-100 rotate-0 opacity-100 group-[.open]:scale-0 group-[.open]:rotate-180 group-[.open]:opacity-0"
          >
            <path fill="currentColor" d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"
            ></path>
          </svg>

          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            class="absolute size-full transition-all duration-500 transform scale-0 -rotate-180 opacity-0 group-[.open]:scale-100 group-[.open]:rotate-0 group-[.open]:opacity-100"
            ><path
              fill="currentColor"
              d="m16.192 6.344l-4.243 4.242l-4.242-4.242l-1.414 1.414L10.535 12l-4.242 4.242l1.414 1.414l4.242-4.242l4.243 4.242l1.414-1.414L13.364 12l4.242-4.242z"
            ></path></svg
          >
        </div>
      </button>
    </div>
  </div>

  <div
    id="navbar-default"
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out max-w-2xl mx-auto px-4 sm:px-0 md:max-w-175"
  >
    <div class="overflow-hidden">
      <div class="grid grid-cols-1 gap-10 pb-12 pt-6 md:grid-cols-2 md:pt-8">
        <div
          class="hidden items-center justify-center rounded-xl md:flex px-6 py-8 bg-[rgb(var(--light),0.25)] dark:bg-[rgb(var(--dark),0.25)]"
        >
          <p
            class="font-inconsolata font-light tracking-tighter leading-relaxed text-base max-w-sm text-[rgb(var(--color),0.65)] [&>strong]:font-medium [&>strong]:text-shadow-[0_0_8px_rgb(var(--color),0.3)]"
          >
            "<strong>Nadie</strong> podrá llevar por encima de su corazón a nadie,
            <strong>ni hacerle mal</strong> en su persona, aunque piense y diga diferente".
          </p>
        </div>

        <nav class="flex flex-col gap-1">
          <HeaderLink href="/" class="group">
            <div class="flex items-center justify-between flex-1">
              <div class="flex items-center gap-4">
                <span class="text-sm">01</span>
                <span
                  class="relative after:absolute after:content-[''] after:left-0 after:right-0 after:top-full after:bg-secondary-500 after:h-0.5 after:transform-[scaleX(0)] after:origin-left after:transition-[transform_0.3s_ease-in-out] hover:after:transform-[scaleX(1)]"
                  >Inicio</span
                >
              </div>
              <svg
                class="size-6 sm:size-8"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"
                ></path>
              </svg>
            </div>
          </HeaderLink>

          <HeaderLink href="/blog" class="group">
            <div class="flex items-center justify-between flex-1">
              <div class="flex items-center gap-4">
                <span class="text-sm">02</span>
                <span
                  class="relative after:absolute after:content-[''] after:left-0 after:right-0 after:top-full after:bg-secondary-500 after:h-0.5 after:transform-[scaleX(0)] after:origin-left after:transition-[transform_0.3s_ease-in-out] hover:after:transform-[scaleX(1)]"
                  >Blog</span
                >
              </div>
              <svg
                class="size-6 sm:size-8"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"
                ></path>
              </svg>
            </div>
          </HeaderLink>

          <HeaderLink href="/projects" class="group">
            <div class="flex items-center justify-between flex-1">
              <div class="flex items-center gap-4">
                <span class="text-sm">03</span>
                <span
                  class="relative after:absolute after:content-[''] after:left-0 after:right-0 after:top-full after:bg-secondary-500 after:h-0.5 after:transform-[scaleX(0)] after:origin-left after:transition-[transform_0.3s_ease-in-out] hover:after:transform-[scaleX(1)]"
                  >Proyectos</span
                >
              </div>
              <svg
                class="size-6 sm:size-8"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"
                ></path>
              </svg>
            </div>
          </HeaderLink>

          <HeaderLink href="/about" class="group">
            <div class="flex items-center justify-between flex-1">
              <div class="flex items-center gap-4">
                <span class="text-sm">04</span>
                <span
                  class="relative after:absolute after:content-[''] after:left-0 after:right-0 after:top-full after:bg-secondary-500 after:h-0.5 after:transform-[scaleX(0)] after:origin-left after:transition-[transform_0.3s_ease-in-out] hover:after:transform-[scaleX(1)]"
                >
                  Acerca
                </span>
              </div>
              <svg
                class="size-6 sm:size-8"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"
                ></path>
              </svg>
            </div>
          </HeaderLink>
        </nav>
      </div>
    </div>
  </div>
</header>

<script>
  const initMenuToggle = () => {
    const btn = document.querySelector(
      '[data-collapse-toggle="navbar-default"]',
    );
    const menu = document.getElementById("navbar-default");

    if (!btn || !menu) return;

    const toggleHandler = () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      btn.classList.toggle("open");
      menu.classList.toggle("grid-rows-[0fr]");
      menu.classList.toggle("grid-rows-[1fr]");
    };

    // Use a single assignment so re-initializing doesn't stack handlers
    (btn as HTMLElement).onclick = toggleHandler;
  };

  initMenuToggle();
  document.addEventListener("astro:after-swap", initMenuToggle);

  const initThemeToggle = () => {
    const button = document.getElementById("theme-toggle");
    const html = document.documentElement;

    const handleThemeToggle = () => {
      html.classList.toggle("dark");
      localStorage.setItem(
        "theme",
        html.classList.contains("dark") ? "dark" : "light",
      );
    };

    // Aplicar tema inicial
    const storedTheme =
      localStorage.getItem("theme") ??
      (window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light");

    html.classList.toggle("dark", storedTheme === "dark");
    button?.addEventListener("click", handleThemeToggle);
  };

  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
